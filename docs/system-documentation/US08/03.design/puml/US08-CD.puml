@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

skinparam class {
    BackgroundColor<<DTO>> White
    BackgroundColor<<Mapper>> White
}

enum DeclarationStatus {
    SUBMITTED
    VALIDATED
    REJECTED
}

enum ValidationVerdict {
    APPROVED
    REJECTED
}

class ApplicationSession {
    - ApplicationSession()
    + {static} getInstance()
    + getCurrentSession()
}

class UserSession {
    + getUserEmail()
}

class EthicsCommitteeMember {
    + validateDeclaration(declaration, verdict, targetReference, commentText)
    - addValidation(validation)
}

class Declaration {
    - submissionDate : LocalDate

    + approve()
    + reject()
}

class Validation {
    - validationDate : LocalDate

    + Validation(declaration, verdict)
    + addAnnotation(text, targetReference, declaration)
}

class Annotation {
    - text : String
    - targetReference : String
    - creationDate : LocalDateTime

    + Annotation(text, targetReference, declaration)
}

class SubmittedDeclarationDTO <<DTO>> {
    + declarationId : String
    + submissionDate : LocalDate
    + status : DeclarationStatus
}

class DeclarationDetailsDTO <<DTO>> {
    + declarationId : String
    + submissionDate : LocalDate
    + status : DeclarationStatus
    + subsidies : List<String>
    + assets : List<String>
    + positions : List<String>
    + securityHoldings : List<String>
}

class ValidationDecisionDTO <<DTO>> {
    + verdict : ValidationVerdict
    + targetReference : String
    + commentText : String
}

class ValidationResultDTO <<DTO>> {
    + declarationId : String
    + status : DeclarationStatus
    + verdict : ValidationVerdict
    + message : String
}

class DeclarationMapper <<Mapper>> {
    + toSubmittedDTOList(declarations) : List<SubmittedDeclarationDTO>
    + toDetailsDTO(declaration) : DeclarationDetailsDTO
    + toResultDTO(declaration, validation) : ValidationResultDTO
}

class Subsidy {
    - amount : double
    - nature : String
}

class Asset {
    - acquisitionValue : double
    - marketValue : double
}

class Position {
    - startDate : LocalDate
    - endDate : LocalDate
    - remuneration : double
}

class SecurityHolding {
    - title : String
    - marketValue : double
    - stake : double
    - percentage : double
}

class DeclarationRepository {
    + getSubmittedDeclarations()
}

class UserRepository {
    + getEthicsCommitteeMemberByEmail(email)
}

class Repositories {
    - Repositories()
    + {static} getInstance()
    + getDeclarationRepository()
    + getUserRepository()
}

class ValidateDeclarationController {
    - declaration : Declaration

    + ValidateDeclarationController()
    + getSubmittedDeclarations() : List<SubmittedDeclarationDTO>
    + selectDeclaration(declarationId) : DeclarationDetailsDTO
    + approveDeclaration(decisionDTO) : ValidationResultDTO
    + rejectDeclaration(decisionDTO) : ValidationResultDTO
    - getEthicsCommitteeMemberFromSession()
}

note right of ValidateDeclarationController
    The selected Declaration is kept
    temporarily by the controller.
end note

note bottom of DeclarationRepository
    Used to obtain the list of
    submitted declarations.
end note

note bottom of Validation
    If the verdict is APPROVED,
    no annotations are required.

    If the verdict is REJECTED,
    at least one annotation/comment
    with a target section/item
    must be recorded.
end note

class ValidateDeclarationUI {
}

ValidateDeclarationUI .> ValidateDeclarationController

ValidateDeclarationController .> Repositories
ValidateDeclarationController ..> DeclarationRepository
ValidateDeclarationController ..> UserRepository
ValidateDeclarationController ..> ApplicationSession
ValidateDeclarationController ..> UserSession
ValidateDeclarationController ..> Declaration
ValidateDeclarationController ..> EthicsCommitteeMember
ValidateDeclarationController ..> ValidationVerdict
ValidateDeclarationController ..> DeclarationMapper
ValidateDeclarationController ..> ValidationDecisionDTO

Repositories -> "1" Repositories : instance
Repositories --> "1" DeclarationRepository : declarationRepository
Repositories --> "1" UserRepository : userRepository

ApplicationSession -> "1" ApplicationSession : instance
ApplicationSession ..> UserSession

DeclarationRepository --> "*" Declaration : declarations
UserRepository --> "*" EthicsCommitteeMember : ethicsCommitteeMembers

EthicsCommitteeMember --> "*" Validation : validations

Validation --> "1" Declaration : declaration
Validation --> "1" ValidationVerdict : verdict
Validation --> "*" Annotation : annotations

Annotation --> "0..1" Declaration : commentsOn

DeclarationMapper ..> Declaration
DeclarationMapper ..> Validation
DeclarationMapper ..> SubmittedDeclarationDTO
DeclarationMapper ..> DeclarationDetailsDTO
DeclarationMapper ..> ValidationResultDTO

Declaration --> "1" DeclarationStatus : status
Declaration --> "*" Subsidy : subsidies
Declaration --> "*" Asset : assets
Declaration --> "*" Position : positions
Declaration --> "*" SecurityHolding : securityHoldings

@enduml
