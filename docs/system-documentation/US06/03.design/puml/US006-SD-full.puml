@startuml US006-SD-full
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

autonumber

actor "Political Agent" as PA

participant ":SubmitDeclarationUI" as UI
participant ":SubmitDeclarationController" as CTRL
participant "ApplicationSession" as APP_SESSION
participant "appSession\n:ApplicationSession" as APP
participant "userSession\n:UserSession" as SESSION
participant "Repositories" as REPOS
participant "repositories\n:Repositories" as REPOS_SINGLETON
participant "politicalAgentRepository\n:PoliticalAgentRepository" as PA_REPO
participant "institutionRepository\n:InstitutionRepository" as INST_REPO
participant "functionRepository\n:FunctionRepository" as FUNC_REPO
participant "declarationRepository\n:DeclarationRepository" as DECL_REPO
participant "politicalAgent\n:PoliticalAgent" as PAO
participant "declaration\n:Declaration" as DECL

activate PA

    PA -> UI : asks to submit a declaration of interests
    activate UI
        UI --> CTRL** : create()

        UI -> CTRL : getDeclarationTypes()
        activate CTRL
            CTRL --> UI : declarationTypes
        deactivate CTRL

        UI -> CTRL : getInstitutions()
        activate CTRL
            CTRL -> REPOS : getInstance()
            activate REPOS
                REPOS --> CTRL : repositories
            deactivate REPOS

            CTRL -> REPOS_SINGLETON : getInstitutionRepository()
            activate REPOS_SINGLETON
                REPOS_SINGLETON --> CTRL : institutionRepository
            deactivate REPOS_SINGLETON

            CTRL -> INST_REPO : getAllInstitutions()
            activate INST_REPO
                INST_REPO --> CTRL : institutions
            deactivate INST_REPO

            CTRL -> CTRL : mapToInstitutionDTOList(institutions)
            activate CTRL
                CTRL --> CTRL : institutionDTOList
            deactivate CTRL

            CTRL --> UI : institutionDTOList
        deactivate CTRL

        UI -> CTRL : getFunctions()
        activate CTRL
            CTRL -> REPOS : getInstance()
            activate REPOS
                REPOS --> CTRL : repositories
            deactivate REPOS

            CTRL -> REPOS_SINGLETON : getFunctionRepository()
            activate REPOS_SINGLETON
                REPOS_SINGLETON --> CTRL : functionRepository
            deactivate REPOS_SINGLETON

            CTRL -> FUNC_REPO : getAllFunctions()
            activate FUNC_REPO
                FUNC_REPO --> CTRL : functions
            deactivate FUNC_REPO

            CTRL -> CTRL : mapToFunctionDTOList(functions)
            activate CTRL
                CTRL --> CTRL : functionDTOList
            deactivate CTRL

            CTRL --> UI : functionDTOList
        deactivate CTRL

        UI --> PA : requests declaration data
    deactivate UI

    PA -> UI : selects declaration type and chooses\nwhether to import previous declaration
    activate UI

        opt import previous declaration requested
            UI -> CTRL : getPreviousDeclaration()
            activate CTRL
                CTRL -> CTRL : getPoliticalAgentFromSession()
                activate CTRL
                    ref over CTRL, PA_REPO
                        Get Political Agent
                    end ref
                    CTRL --> CTRL : politicalAgent
                deactivate CTRL

                CTRL -> REPOS : getInstance()
                activate REPOS
                    REPOS --> CTRL : repositories
                deactivate REPOS

                CTRL -> REPOS_SINGLETON : getDeclarationRepository()
                activate REPOS_SINGLETON
                    REPOS_SINGLETON --> CTRL : declarationRepository
                deactivate REPOS_SINGLETON

                CTRL -> DECL_REPO : findLastByPoliticalAgent(politicalAgent)
                activate DECL_REPO
                    DECL_REPO --> CTRL : previousDeclaration
                deactivate DECL_REPO

                CTRL -> CTRL : mapToDeclarationDTO(previousDeclaration)
                activate CTRL
                    CTRL --> CTRL : previousDeclarationDTO
                deactivate CTRL

                CTRL --> UI : previousDeclarationDTO
            deactivate CTRL

            UI --> PA : presents pre-filled household members,\npositions, subsidies, assets and\nsecurity holdings from previous declaration
        end

        UI --> PA : requests household, position, subsidy,\nasset and security holding data
    deactivate UI

    PA -> UI : provides declaration data\n(household members, positions, subsidies,\nassets, security holdings, and,\nif Exceptional, amendment data)
    activate UI
        UI --> PA : shows entered data and requests confirmation
    deactivate UI

    PA -> UI : confirms declaration submission
    activate UI
        UI -> CTRL : submitDeclaration(declarationDTO)
        activate CTRL

            CTRL -> CTRL : getPoliticalAgentFromSession()
            activate CTRL
                ref over CTRL, PA_REPO
                    Get Political Agent
                end ref
                CTRL --> CTRL : politicalAgent
            deactivate CTRL

            CTRL -> REPOS : getInstance()
            activate REPOS
                REPOS --> CTRL : repositories
            deactivate REPOS

            CTRL -> REPOS_SINGLETON : getDeclarationRepository()
            activate REPOS_SINGLETON
                REPOS_SINGLETON --> CTRL : declarationRepository
            deactivate REPOS_SINGLETON

            alt declarationDTO.type == INITIAL
                CTRL -> DECL_REPO : existsInitialDeclaration(politicalAgent)
                activate DECL_REPO
                    DECL_REPO --> CTRL : false
                deactivate DECL_REPO
            else declarationDTO.type == REGULAR
                CTRL -> DECL_REPO : existsRegularDeclarationForYear(politicalAgent, year)
                activate DECL_REPO
                    DECL_REPO --> CTRL : false
                deactivate DECL_REPO
            end

            CTRL -> PAO : createDeclaration(declarationDTO.type)
            activate PAO
                PAO --> DECL** : create(declarationType, submissionDate)
                PAO --> CTRL : declaration
            deactivate PAO

            loop for each householdMemberDTO
                CTRL -> DECL : addHouseholdMember(householdMemberDTO.name,\nhouseholdMemberDTO.taxId, householdMemberDTO.birthDate,\nhouseholdMemberDTO.relationship)
                activate DECL
                    DECL --> CTRL : householdMember
                deactivate DECL
            end

            loop for each positionDTO
                CTRL -> INST_REPO : getById(positionDTO.institutionId)
                activate INST_REPO
                    INST_REPO --> CTRL : institution
                deactivate INST_REPO

                CTRL -> FUNC_REPO : getById(positionDTO.functionId)
                activate FUNC_REPO
                    FUNC_REPO --> CTRL : function
                deactivate FUNC_REPO

                CTRL -> DECL : addPosition(positionDTO.positionType, positionDTO.startDate,\npositionDTO.endDate, positionDTO.remuneration, function, institution)
                activate DECL
                    DECL --> CTRL : position
                deactivate DECL
            end

            loop for each subsidyDTO
                CTRL -> INST_REPO : getById(subsidyDTO.institutionId)
                activate INST_REPO
                    INST_REPO --> CTRL : institution
                deactivate INST_REPO

                CTRL -> DECL : addSubsidy(subsidyDTO.amount, subsidyDTO.nature, institution)
                activate DECL
                    DECL --> CTRL : subsidy
                deactivate DECL
            end

            loop for each assetDTO
                CTRL -> CTRL : mapToLocation(assetDTO.location)
                activate CTRL
                    CTRL --> CTRL : location
                deactivate CTRL

                CTRL -> DECL : addAsset(assetDTO.propertyType, assetDTO.acquisitionValue,\nassetDTO.marketValue, location)
                activate DECL
                    DECL --> CTRL : asset
                deactivate DECL
            end

            loop for each securityHoldingDTO
                CTRL -> INST_REPO : getById(securityHoldingDTO.institutionId)
                activate INST_REPO
                    INST_REPO --> CTRL : institution
                deactivate INST_REPO

                CTRL -> DECL : addSecurityHolding(securityHoldingDTO.title, securityHoldingDTO.marketValue,\nsecurityHoldingDTO.stake, securityHoldingDTO.percentage, institution)
                activate DECL
                    DECL --> CTRL : securityHolding
                deactivate DECL
            end

            alt declarationDTO.type == EXCEPTIONAL
                CTRL -> DECL : setAmendmentReason(declarationDTO.amendmentReason)
                activate DECL
                deactivate DECL

                opt declarationDTO.amendedDeclarationId != null
                    CTRL -> DECL_REPO : getById(declarationDTO.amendedDeclarationId)
                    activate DECL_REPO
                        DECL_REPO --> CTRL : amendedDeclaration
                    deactivate DECL_REPO

                    CTRL -> DECL : setAmendedDeclaration(amendedDeclaration)
                    activate DECL
                    deactivate DECL
                end
            end

            CTRL -> DECL : validateData()
            activate DECL
                DECL --> CTRL : true
            deactivate DECL

            CTRL -> DECL_REPO : save(declaration)
            activate DECL_REPO
                DECL_REPO --> CTRL : declaration
            deactivate DECL_REPO

            CTRL --> UI : declaration
        deactivate CTRL

        UI --> PA : informs that the declaration was successfully submitted
    deactivate UI

deactivate PA

@enduml
