@startuml US006-SD-split
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

autonumber

actor "Political Agent" as PA

participant ":SubmitDeclarationUI" as UI
participant ":SubmitDeclarationController" as CTRL
participant "Repositories" as REPOS
participant "declaration\n:Declaration" as DECL

activate PA

    PA -> UI : asks to submit a declaration of interests
    activate UI
        UI --> CTRL** : create()

        UI -> CTRL : getDeclarationTypes()
        activate CTRL
            CTRL --> UI : declarationTypes
        deactivate CTRL

        UI -> CTRL : getInstitutions()
        activate CTRL
            ref over CTRL, REPOS
                Get Institutions
            end ref
            CTRL --> UI : institutionDTOList
        deactivate CTRL

        UI -> CTRL : getFunctions()
        activate CTRL
            ref over CTRL, REPOS
                Get Functions
            end ref
            CTRL --> UI : functionDTOList
        deactivate CTRL

        UI --> PA : requests declaration data
    deactivate UI

    PA -> UI : selects declaration type and chooses\nwhether to import previous declaration
    activate UI

        opt import previous declaration requested
            UI -> CTRL : getPreviousDeclaration()
            activate CTRL
                ref over CTRL, REPOS
                    Get Previous Declaration
                end ref
                CTRL --> UI : previousDeclarationDTO
            deactivate CTRL

            UI --> PA : presents pre-filled data from\nprevious declaration
        end

        UI --> PA : requests household, position, subsidy,\nasset and security holding data
    deactivate UI

    PA -> UI : provides declaration data
    activate UI
        UI --> PA : shows entered data and requests confirmation
    deactivate UI

    PA -> UI : confirms declaration submission
    activate UI
        UI -> CTRL : submitDeclaration(declarationDTO)
        activate CTRL

            CTRL -> CTRL : getPoliticalAgentFromSession()
            activate CTRL
                ref over CTRL
                    Get Political Agent
                end ref
                CTRL --> CTRL : politicalAgent
            deactivate CTRL

            ref over CTRL, DECL
                Create Declaration
            end ref

            CTRL --> UI : declaration
        deactivate CTRL

        UI --> PA : informs that the declaration was successfully submitted
    deactivate UI

deactivate PA

@enduml
