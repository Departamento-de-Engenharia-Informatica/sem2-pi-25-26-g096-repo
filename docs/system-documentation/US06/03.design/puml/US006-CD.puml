@startuml US006-CD
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
skinparam classAttributeIconSize 0

class SubmitDeclarationUI {
    + run()
}

class SubmitDeclarationController {
    + SubmitDeclarationController()
    + getDeclarationTypes()
    + getInstitutions()
    + getFunctions()
    + getPreviousDeclaration()
    + submitDeclaration(declarationDTO)
    - getPoliticalAgentFromSession()
    - mapToInstitutionDTOList(institutions) : List<InstitutionDTO>
    - mapToFunctionDTOList(functions) : List<FunctionDTO>
    - mapToDeclarationDTO(declaration) : DeclarationDTO
    - mapToLocation(locationDTO) : Location
}

class ApplicationSession {
    - ApplicationSession()
    + {static} getInstance()
    + getCurrentSession()
}

class UserSession {
    + getUserId()
}

class Repositories {
    - Repositories()
    + {static} getInstance()
    + getPoliticalAgentRepository()
    + getInstitutionRepository()
    + getFunctionRepository()
    + getDeclarationRepository()
}

class PoliticalAgentRepository {
    + getByUserId(userId)
}

class InstitutionRepository {
    + getAllInstitutions()
    + getById(id)
}

class FunctionRepository {
    + getAllFunctions()
    + getById(id)
}

class DeclarationRepository {
    + save(declaration)
    + findLastByPoliticalAgent(politicalAgent)
    + existsInitialDeclaration(politicalAgent)
    + existsRegularDeclarationForYear(politicalAgent, year)
    + getById(id)
}

class PoliticalAgent {
    - name : String
    - taxId : String
    - email : String
    - password : String

    + createDeclaration(declarationType)
}

class Declaration {
    - submissionDate : LocalDate
    - amendmentReason : String

    + Declaration(declarationType, submissionDate)
    + addHouseholdMember(name, taxId, birthDate, relationship)
    + addPosition(positionType, startDate, endDate,\nremuneration, function, institution)
    + addSubsidy(amount, nature, institution)
    + addAsset(propertyType, acquisitionValue,\nmarketValue, location)
    + addSecurityHolding(title, marketValue,\nstake, percentage, institution)
    + setAmendmentReason(amendmentReason)
    + setAmendedDeclaration(amendedDeclaration)
    + validateData()
    + getSubmissionDate()
    + getStatus()
    + getType()
    + getHouseholdMembers()
    + getPositions()
    + getSubsidies()
    + getAssets()
    + getSecurityHoldings()
}

note bottom of Declaration
    Each add* operation validates the entry
    before adding it to the declaration.
    validateData() performs the final global validation,
    including AC1 (at least one household member),
    AC7 (at least one financial entry), and AC6
    (exceptional declarations require amendmentReason
    and/or an amended declaration reference).
    get* operations expose collections to support
    mapToDeclarationDTO in getPreviousDeclaration().
end note

class HouseholdMember {
    - name : String
    - taxId : String
    - birthDate : LocalDate
}

class Position {
    - startDate : LocalDate
    - endDate : LocalDate
    - remuneration : double
}

class Subsidy {
    - amount : double
    - nature : String
}

class Asset {
    - acquisitionValue : double
    - marketValue : double
}

class Location {
    - parish : String
    - county : String
    - district : String
}

class SecurityHolding {
    - title : String
    - marketValue : double
    - stake : double
    - percentage : double
}

class Institution {
    - name : String
    - taxId : String
}

class Function {
    - designation : String
}

class DeclarationDTO {
    + type : DeclarationType
    + amendmentReason : String
    + amendedDeclarationId : String
    + householdMembers : List<HouseholdMemberDTO>
    + positions : List<PositionDTO>
    + subsidies : List<SubsidyDTO>
    + assets : List<AssetDTO>
    + securityHoldings : List<SecurityHoldingDTO>
}

class HouseholdMemberDTO {
    + name : String
    + taxId : String
    + birthDate : LocalDate
    + relationship : HouseholdRelationship
}

class PositionDTO {
    + positionType : PositionType
    + startDate : LocalDate
    + endDate : LocalDate
    + remuneration : double
    + functionId : String
    + institutionId : String
}

class SubsidyDTO {
    + amount : double
    + nature : String
    + institutionId : String
}

class AssetDTO {
    + propertyType : PropertyType
    + acquisitionValue : double
    + marketValue : double
    + location : LocationDTO
}

class LocationDTO {
    + parish : String
    + county : String
    + district : String
}

class SecurityHoldingDTO {
    + title : String
    + marketValue : double
    + stake : double
    + percentage : double
    + institutionId : String
}

class InstitutionDTO {
    + id : String
    + name : String
}

class FunctionDTO {
    + id : String
    + designation : String
}

enum DeclarationType {
    INITIAL
    REGULAR
    EXCEPTIONAL
}

enum DeclarationStatus {
    SUBMITTED
    VALIDATED
    REJECTED
}

enum PositionType {
    PUBLIC
    PRIVATE
    SOCIAL
}

enum PropertyType {
    URBAN
    RURAL
}

enum HouseholdRelationship {
    PARTNER
    DESCENDANT
    OTHER
}

SubmitDeclarationUI .> SubmitDeclarationController

SubmitDeclarationController .> Repositories
SubmitDeclarationController ..> ApplicationSession
SubmitDeclarationController ..> UserSession
SubmitDeclarationController ..> PoliticalAgentRepository
SubmitDeclarationController ..> InstitutionRepository
SubmitDeclarationController ..> FunctionRepository
SubmitDeclarationController ..> DeclarationRepository
SubmitDeclarationController ..> DeclarationDTO
SubmitDeclarationController ..> InstitutionDTO
SubmitDeclarationController ..> FunctionDTO
SubmitDeclarationController ..> PoliticalAgent
SubmitDeclarationController ..> Declaration

ApplicationSession -> "1" ApplicationSession : instance
ApplicationSession ..> UserSession

Repositories -> "1" Repositories : instance
Repositories --> "1" PoliticalAgentRepository : politicalAgentRepository
Repositories --> "1" InstitutionRepository : institutionRepository
Repositories --> "1" FunctionRepository : functionRepository
Repositories --> "1" DeclarationRepository : declarationRepository

PoliticalAgentRepository --> "*" PoliticalAgent : politicalAgents
InstitutionRepository --> "*" Institution : institutions
FunctionRepository --> "*" Function : functions
DeclarationRepository --> "*" Declaration : declarations

PoliticalAgent "1" *-- "0..*" Declaration : submits >
Declaration --> "1" DeclarationType : type
Declaration --> "1" DeclarationStatus : status
Declaration "0..*" -- "0..1" Declaration : amends >

Declaration "1" *-- "1..*" HouseholdMember : declares >
Declaration "1" *-- "0..*" Position : contains >
Declaration "1" *-- "0..*" Subsidy : contains >
Declaration "1" *-- "0..*" Asset : contains >
Declaration "1" *-- "0..*" SecurityHolding : contains >

HouseholdMember --> "1" HouseholdRelationship : relationship

Position --> "1" PositionType : type
Position "*" --> "1" Institution : held at >
Position "*" --> "1" Function : designated as >

Subsidy "*" --> "1" Institution : received from >

Asset --> "1" PropertyType : type
Asset "1" --> "1" Location : located in >

SecurityHolding "*" --> "1" Institution : held in >

DeclarationDTO ..> HouseholdMemberDTO
DeclarationDTO ..> PositionDTO
DeclarationDTO ..> SubsidyDTO
DeclarationDTO ..> AssetDTO
DeclarationDTO ..> SecurityHoldingDTO
AssetDTO ..> LocationDTO
HouseholdMemberDTO --> "1" HouseholdRelationship

@enduml
