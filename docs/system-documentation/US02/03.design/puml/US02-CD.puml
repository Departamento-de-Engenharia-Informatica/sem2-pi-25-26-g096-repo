@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
skinparam classAttributeIconSize 0

skinparam class {
    BackgroundColor<<DTO>> White
    BackgroundColor<<Mapper>> White
    BackgroundColor<<Adapter>> White
    BackgroundColor<<External>> White
    BackgroundColor<<Factory>> White
}

enum RequestedRole {
    POLITICAL_AGENT
    CITIZEN
    JOURNALIST
    ETHICS_COMMITTEE_MEMBER
}

enum RequestStatus {
    PENDING
    ACCEPTED
    REJECTED
}

abstract class User {
    - name : String
    - taxId : String
    - email : String
    - password : String
}

class PoliticalAgent {
}

class Citizen {
}

class Journalist {
    - pressCardNumber : String
}

class EthicsCommitteeMember {
}

class Administrator {
}

class RegistrationRequest {
    - requestDate : LocalDate
    - decisionDate : LocalDateTime
    - name : String
    - taxId : String
    - email : String
    - password : String
    - nationalIdentityCardNumber : String
    - pressCardNumber : String
    - requestedPosition : String
    - requestedInstitution : String

    + accept(administrator) : User
    + reject(administrator, rejectionReason) : Annotation
    - createUser() : User
    - registerDecision(administrator)
}

class Annotation {
    - text : String
    - creationDate : LocalDateTime

    + Annotation(text)
}

class Notification {
    - recipientEmail : String
    - subject : String
    - message : String
    - sentDate : LocalDateTime
}

class PendingRegistrationRequestDTO <<DTO>> {
    + requestId : String
    + requestDate : LocalDate
    + requestedRole : RequestedRole
}

class RegistrationRequestDetailsDTO <<DTO>> {
    + requestId : String
    + name : String
    + taxId : String
    + email : String
    + requestedRole : RequestedRole
    + nationalIdentityCardNumber : String
    + pressCardNumber : String
    + requestedPosition : String
    + requestedInstitution : String
}

class RegistrationDecisionDTO <<DTO>> {
    + accepted : boolean
    + rejectionReason : String
}

class RegistrationDecisionNotificationDTO <<DTO>> {
    + recipientEmail : String
    + subject : String
    + message : String
}

class RegistrationRequestMapper <<Mapper>> {
    + toPendingDTOList(requests) : List<PendingRegistrationRequestDTO>
    + toDetailsDTO(request) : RegistrationRequestDetailsDTO
    + toNotificationDTO(request, annotation) : RegistrationDecisionNotificationDTO
}

interface EmailService {
    + sendRegistrationDecisionNotification(notificationDTO)
}

class GmailEmailServiceAdapter <<Adapter>> {
    + sendRegistrationDecisionNotification(notificationDTO)
}

class DeiEmailServiceAdapter <<Adapter>> {
    + sendRegistrationDecisionNotification(notificationDTO)
}

class GmailEmailAPI <<External>> {
    + send(to, subject, body)
}

class DeiEmailAPI <<External>> {
    + sendMessage(to, subject, body)
}

class EmailServiceFactory <<Factory>> {
    + createEmailService() : EmailService
}

class ApplicationProperties {
    + getProperty(key) : String
}

class RegistrationRequestRepository {
    + getPendingRegistrationRequests()
    + addRegistrationRequest(registrationRequest)
    + validateRegistrationRequest(registrationRequest)
}

class UserRepository {
    + addUser(user)
    + validateUser(user)
    + getAdministratorByEmail(email)
}

class Repositories {
    - Repositories()
    + {static} getInstance()
    + getRegistrationRequestRepository()
    + getUserRepository()
}

class ApplicationSession {
    - ApplicationSession()
    + {static} getInstance()
    + getCurrentSession()
}

class UserSession {
    + getUserEmail()
}

class ApproveRejectRegistrationController {
    - registrationRequest : RegistrationRequest

    + ApproveRejectRegistrationController()
    + getPendingRegistrationRequests() : List<PendingRegistrationRequestDTO>
    + selectRegistrationRequest(requestId) : RegistrationRequestDetailsDTO
    + acceptRegistrationRequest(decisionDTO) : RegistrationRequestDetailsDTO
    + rejectRegistrationRequest(decisionDTO) : RegistrationRequestDetailsDTO
    - getAdministratorFromSession() : Administrator
    - notifyRequester(request, annotation)
}

class ApproveRejectRegistrationUI {
}

User <|-- PoliticalAgent
User <|-- Citizen
User <|-- Journalist
User <|-- EthicsCommitteeMember
User <|-- Administrator

ApproveRejectRegistrationUI .> ApproveRejectRegistrationController

ApproveRejectRegistrationController .> Repositories
ApproveRejectRegistrationController ..> RegistrationRequestRepository
ApproveRejectRegistrationController ..> UserRepository
ApproveRejectRegistrationController ..> RegistrationRequestMapper
ApproveRejectRegistrationController ..> EmailServiceFactory
ApproveRejectRegistrationController ..> EmailService
ApproveRejectRegistrationController ..> RegistrationDecisionDTO
ApproveRejectRegistrationController ..> ApplicationSession
ApproveRejectRegistrationController ..> UserSession

RegistrationRequestMapper ..> RegistrationRequest
RegistrationRequestMapper ..> Annotation
RegistrationRequestMapper ..> PendingRegistrationRequestDTO
RegistrationRequestMapper ..> RegistrationRequestDetailsDTO
RegistrationRequestMapper ..> RegistrationDecisionNotificationDTO

EmailService <|.. GmailEmailServiceAdapter
EmailService <|.. DeiEmailServiceAdapter
GmailEmailServiceAdapter ..> GmailEmailAPI : adapts >
DeiEmailServiceAdapter ..> DeiEmailAPI : adapts >
EmailServiceFactory ..> ApplicationProperties
EmailServiceFactory ..> EmailService : creates using reflection >

Repositories -> "1" Repositories : instance
Repositories --> "1" RegistrationRequestRepository : registrationRequestRepository
Repositories --> "1" UserRepository : userRepository

ApplicationSession -> "1" ApplicationSession : instance
ApplicationSession ..> UserSession

RegistrationRequestRepository --> "*" RegistrationRequest : registrationRequests
UserRepository --> "*" User : users

RegistrationRequest --> "1" RequestedRole : requestedRole
RegistrationRequest --> "1" RequestStatus : status
RegistrationRequest --> "0..1" User : createdUser
RegistrationRequest --> "0..1" Administrator : reviewedBy
RegistrationRequest --> "0..1" Annotation : rejectionAnnotation
RegistrationRequest --> "0..1" Notification : decisionNotification
Notification ..> "0..1" Annotation : may include reason from >

note bottom of EmailService
    Stable interface used by the system.
    Concrete email providers are hidden
    behind adapters.
end note

note bottom of EmailServiceFactory
    Reads the configured adapter class
    from a properties file and creates it
    using Java Reflection.
end note

@enduml
