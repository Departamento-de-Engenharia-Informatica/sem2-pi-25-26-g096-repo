@startuml
title US02 - Approve/Reject Registration
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

hide circle
hide methods

show <<Abstract>> circle
show <<Enum>> circle

skinparam class {
    BackgroundColor<<Abstract>> White
    BackgroundColor<<Enum>> White
}

enum RequestedRole << Enum >> {
  POLITICAL_AGENT
  CITIZEN
  JOURNALIST
  ETHICS_COMMITTEE_MEMBER
}

enum RequestStatus << Enum >> {
  PENDING
  ACCEPTED
  REJECTED
}

abstract class User << Abstract >> {
  name
  taxId
  email
  password
}

class FutureUser {
}

class PoliticalAgent {
}

class Citizen {
}

class Journalist {
  pressCardNumber
}

class EthicsCommitteeMember {
}

class Administrator {
}

class RegistrationRequest {
  requestDate
  decisionDate
  name
  taxId
  email
  password
  nationalIdentityCardNumber
  pressCardNumber
  requestedPosition
  requestedInstitution
}

class Annotation {
  text
  creationDate
}

User <|-- PoliticalAgent
User <|-- Citizen
User <|-- Journalist
User <|-- EthicsCommitteeMember
User <|-- Administrator

FutureUser "1" -- "0..*" RegistrationRequest : requests >
Administrator "1" -- "0..*" RegistrationRequest : reviews >

RegistrationRequest --> "1" RequestStatus
RegistrationRequest --> "1" RequestedRole

RegistrationRequest "1" -- "0..1" User : creates if accepted >
Annotation "0..*" -- "0..1" RegistrationRequest : justifies rejection of >

@enduml