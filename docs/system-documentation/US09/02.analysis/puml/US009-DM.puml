@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle
hide methods

class EthicsCommitteeMember {
    name
    taxId
    email
}

class PoliticalAgent {
}

class Role {
    designation
}

class PoliticalMandate {
    startDate
    endDate
}

class Declaration {
    submissionDate
    declarantName
}

enum DeclarationType {
    INITIAL
    REGULAR
    EXCEPTIONAL
}

enum DeclarationStatus {
    SUBMITTED
    VALIDATED
    REJECTED
}

abstract class Section {
}

class IncomeSection {
}

class AssetSection {
}

class PositionSection {
}

class ShareholdingSection {
}

Section <|-- IncomeSection
Section <|-- AssetSection
Section <|-- PositionSection
Section <|-- ShareholdingSection

PoliticalAgent "1" -- "0..*" PoliticalMandate : holds >
PoliticalMandate "*" -- "1" Role : associated with >

PoliticalAgent "1" -- "0..*" Declaration : submits >
Declaration --> "1" DeclarationType
Declaration --> "1" DeclarationStatus
Declaration *-- "4" Section

EthicsCommitteeMember "1" -- "0..*" Declaration : consults >

@enduml