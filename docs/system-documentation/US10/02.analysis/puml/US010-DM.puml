@startuml
top to bottom direction
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle
hide methods

class PoliticalAgent {
    name
    email
}

class Declaration {
    submissionDate
    type
}

class Position {
    remuneration
}

class Subsidy {
    amount
}

PoliticalAgent "1" -down- "0..*" Declaration : submits
Declaration "1" -down- "0..*" Position : includes
Declaration "1" -down- "0..*" Subsidy : includes

@enduml