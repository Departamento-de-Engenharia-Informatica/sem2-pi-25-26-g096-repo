@startuml
title US01 — User Registration Request
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle
hide methods

skinparam class {
    BackgroundColor<<Abstract>> White
    BackgroundColor<<Enum>> White
}

enum RequestedRole << Enum >> {
  POLITICAL_AGENT
  CITIZEN
  JOURNALIST
  ETHICS_COMMITTEE_MEMBER
}

enum RequestStatus << Enum >> {
  PENDING
  ACCEPTED
  REJECTED
}

abstract class User << Abstract >> {
    name
    taxId
    email
    password
}

class RegistrationRequest {
    requestDate
}

User "1" -- "0..*" RegistrationRequest : requests >
RegistrationRequest --> "1" RequestStatus
RegistrationRequest "1" -- "1" RequestedRole : refers to >

@enduml