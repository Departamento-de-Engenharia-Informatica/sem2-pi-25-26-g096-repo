@startuml
title Domain Model
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

hide circle
hide methods

skinparam class {
    BackgroundColor<<Abstract>> White
    BackgroundColor<<Enum>> White
}

enum PoliticalOffice << Enum >> {
  DEPUTY
  MINISTER
  COUNCILLOR
  MAYOR
  PARISH_COUNCIL_PRESIDENT
}

enum DeclarationType << Enum >> {
  INITIAL
  REGULAR
  EXCEPTIONAL
}

enum PropertyType << Enum >> {
  URBAN
  RURAL
}

enum PositionType << Enum >> {
  PUBLIC
  PRIVATE
  SOCIAL
}

enum InstitutionType << Enum >> {
  COMPANY
  POLITICAL_PARTY
  FOUNDATION
  INSTITUTE
  ASSOCIATION
}

enum DeclarationStatus << Enum >> {
  SUBMITTED
  VALIDATED
  REJECTED
}

enum ComplaintStatus << Enum >> {
  SUBMITTED
  UNDER_REVIEW
  CLOSED
}

enum RequestStatus << Enum >> {
  PENDING
  ACCEPTED
  REJECTED
}

enum ValidationVerdict << Enum >> {
  APPROVED
  REJECTED
}

enum RequestedRole << Enum >> {
  POLITICAL_AGENT
  CITIZEN
  JOURNALIST
  ETHICS_COMMITTEE_MEMBER
}

abstract class User << Abstract >> {
  name
  taxId
  email
  password
}

class PoliticalAgent {
}

class Journalist {
  pressCardNumber
}

class Citizen {
}

class EthicsCommitteeMember {
}

class Administrator {
}

class RegistrationRequest {
  requestDate
}

class PoliticalMandate {
  startDate
  endDate
}

class Institution {
  name
  taxId
}

class Function {
  designation
}

class Declaration {
  submissionDate
}

class Validation {
  validationDate
}

class Annotation {
  text
  creationDate
}

class Subsidy {
  amount
  nature
}

class Asset {
  acquisitionValue
  marketValue
}

class Location {
  parish
  municipality
  district
}

class Position {
  startDate
  endDate
  remuneration
}

class SecurityHolding {
  title
  marketValue
  stake
  percentage
}

class Complaint {
  incidentDate
  submissionDate
  description
}

User <|-- PoliticalAgent
User <|-- Journalist
User <|-- Citizen
User <|-- EthicsCommitteeMember
User <|-- Administrator

User "1" -- "0..*" RegistrationRequest : requests >
RegistrationRequest --> "1" RequestStatus
RegistrationRequest --> "1" RequestedRole
Administrator "1" -- "0..*" RegistrationRequest : reviews >

PoliticalAgent "1" -- "0..*" PoliticalMandate : holds >
PoliticalMandate --> "1" PoliticalOffice

Institution --> "1" InstitutionType
Administrator "1" -- "0..*" Institution : registers >
Administrator "1" -- "0..*" Function : registers >

PoliticalAgent "1" -- "0..*" Declaration : submits >
Declaration --> "1" DeclarationType
Declaration --> "1" DeclarationStatus
Declaration "1" *--- "0..*" Subsidy : contains >
Declaration "1" *--- "0..*" Asset : contains >
Declaration "1" *--- "0..*" Position : contains >
Declaration "1" *--- "0..*" SecurityHolding : contains >

Subsidy "0..*" -- "1" Institution : received from >

Asset --> "1" PropertyType
Asset "1" -- "1" Location : located in >

Position --> "1" PositionType
Position "*" -- "1" Institution : held at >
Position "*" -- "1" Function : designated as >

SecurityHolding "*" -- "1" Institution : held in >

EthicsCommitteeMember "1" -- "0..*" Validation : performs >
Validation "1" -- "1" Declaration : evaluates >
Validation --> "1" ValidationVerdict
Validation "1" *-- "0..*" Annotation : contains >
Annotation "0..*" -- "0..1" Subsidy : comments on >
Annotation "0..*" -- "0..1" Asset : comments on >
Annotation "0..*" -- "0..1" Position : comments on >
Annotation "0..*" -- "0..1" SecurityHolding : comments on >

Citizen "1" -- "0..*" Complaint : submits >
Journalist "1" -- "0..*" Complaint : submits >
Complaint "*" -- "1" PoliticalMandate : in context of >
Complaint --> "1" ComplaintStatus

@enduml