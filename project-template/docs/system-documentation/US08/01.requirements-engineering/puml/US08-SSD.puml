@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

autonumber

actor "Ethics Committee\nMember" as Member
participant ":System" as System

activate Member

    Member -> System : asks to validate a declaration of interests
    activate System

        System --> Member : shows submitted declaration
    deactivate System

    Member -> System : analyzes declaration
    activate System

        System --> Member : requests validation decision
    deactivate System

    Member -> System : validates declaration
    activate System

        System --> Member : displays validation success
    deactivate System

    Member -> System : comments inconsistencies
    activate System

        System --> Member : displays operation success
    deactivate System

deactivate Member

@enduml